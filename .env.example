# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ===============================================
# BANCO DE DADOS (SUPABASE)
# ===============================================
# Colete essas chaves nas configurações "API" do projeto no site Supabase
NEXT_PUBLIC_SUPABASE_URL="sua_url_do_supabase"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua_anon_key_do_supabase"
SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_do_supabase"

# ===============================================
# GOOGLE CALENDAR
# ===============================================
# O ID do calendário principal do barbeiro onde os eventos serão salvos.
# Você pega isso nas configurações da agenda do Google (Ex: "seuemail@gmail.com" ou um ID estranho)
GOOGLE_CALENDAR_ID="seu_calendario_id@group.calendar.google.com"
